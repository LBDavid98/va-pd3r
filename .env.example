# PD3r Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# REQUIRED
# =============================================================================
OPENAI_API_KEY=sk-...

# =============================================================================
# OPENAI CONFIGURATION (Optional - defaults shown)
# =============================================================================
# OPENAI_ORG_ID=
# OPENAI_DEFAULT_MODEL=gpt-4o
# OPENAI_MAX_RETRIES=3
# OPENAI_TIMEOUT=60

# =============================================================================
# LANGSMITH (Tracing & Monitoring)
# =============================================================================
# Enable cloud tracing (requires LangSmith account)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=pd3r

# =============================================================================
# PD3R CONFIGURATION
# =============================================================================
# Enable local tracing (writes to output/logs/)
PD3R_TRACING=true

# Stop execution at a specific phase (for testing): interview, requirements, drafting, review
# PD3R_STOP_AT=

# Skip QA review during drafting (for testing)
# PD3R_SKIP_QA=false

# =============================================================================
# ENVIRONMENT
# =============================================================================
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

# =============================================================================
# AGENT CONFIGURATION
# =============================================================================
MAX_AGENT_ITERATIONS=10
AGENT_TIMEOUT=300
